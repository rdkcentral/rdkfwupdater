librdkFwupdateMgr_la_SOURCES = \
    ${top_srcdir}/librdkFwupdateMgr/src/rdkFwupdateMgr_process.c \
    ${top_srcdir}/librdkFwupdateMgr/src/rdkFwupdateMgr_log.c \
